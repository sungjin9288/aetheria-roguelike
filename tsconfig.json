{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    /* JS 호환 — 기존 .js/.jsx 파일도 type-check */
    "allowJs": true,
    "checkJs": false,

    /* 호환성 (Vite 등 번들러용) */
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    /* cycle 58 phase 6 — noImplicitAny 거의 도달 (1702→156).
     * 156 잔여는 TS7053(index access by any) + 일부 TS7006 — 다음 사이클 manual fix.
     * 현재는 false로 유지 (type-check 통과). 향후 strict 단계적 활성. */
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noUnusedLocals": false,

    /* Vite/Capacitor가 emit 담당. tsc는 type-check만. */
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "android", "ios", "scripts/_archive", "output"]
}
