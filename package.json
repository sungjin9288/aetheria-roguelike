{
  "name": "aetheria-rpg",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test:unit": "node --test tests/*.test.js",
    "preview": "vite preview",
    "mobile:doctor": "bash scripts/mobile-doctor.sh",
    "cap:sync": "npm run build && npx cap sync",
    "android:sync": "npm run build && npx cap sync android",
    "android:debug": "bash scripts/android-gradle.sh assembleDebug",
    "android:release:apk": "bash scripts/android-gradle.sh assembleRelease",
    "android:release": "bash scripts/android-gradle.sh bundleRelease",
    "android:open": "npx cap open android",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:build:device": "bash scripts/ios-build-device.sh",
    "ios:archive": "bash scripts/ios-archive.sh",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "chart.js": "^4.5.1",
    "firebase": "^12.8.0",
    "framer-motion": "^12.34.2",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.4"
  }
}
